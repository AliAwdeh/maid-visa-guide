# Copy to .env and fill in. Bun auto-loads .env into process.env (dev + prod).

# Shared bearer token. Gates POST /api/guides, GET /api/admin, and the
# token-entry on /debug and /admin/admin. Generate a strong random value:
#   bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(24))).toString('base64url'))"
API_TOKEN=change-me

# Public origin used to build the returned /Views link. Falls back to the
# request origin if unset.
PUBLIC_APP_HOST=https://maidscc.app

# Comma-separated browser origins allowed to call the API. Server-to-server
# calls (no Origin header) are always allowed — the bearer token is the gate.
ALLOWED_ORIGINS=https://maidscc.app,http://localhost:5173,http://localhost:3000

# SQLite file location (created on first run).
DB_PATH=./data/app.db

# Port for the production Bun server (server/serve.ts).
PORT=3000
